// Place your key bindings in this file to override the defaults
[
    {
        "key": "cmd+i",
        "command": "composerMode.agent"
    },

    // -------------------------------------------------------------------------
    // Window manager shortcut passthrough
    // These are unbound so the OS/window manager (e.g. Rectangle) handles them
    // instead of Cursor intercepting them.
    // -------------------------------------------------------------------------
    { "key": "ctrl+alt+enter", "command": "-editor.action.insertLineBefore" },
    { "key": "ctrl+alt+left",  "command": "-workbench.action.navigateBack" },
    { "key": "ctrl+alt+right", "command": "-workbench.action.navigateForward" }
]